# ========================================
# .ENV.EXAMPLE - $10,000+ LUXURY MERN MARKETPLACE (FULLSTACK)
# ========================================
# ⚠️  ABSOLUTE CRITICAL SECURITY WARNING ⚠️
# 
# 🚨 NEVER, EVER commit .env files with REAL values to Git!
# 🚨 Add .env* to .gitignore IMMEDIATELY
# 🚨 Use different values for dev/staging/prod
# 🚨 Rotate ALL API keys every 90 days
# 🚨 Enable 2FA on ALL payment provider accounts
# 🚨 Monitor logs for unauthorized access
# 
# Copy this → .env → Fill → Add to .gitignore
# ========================================
# Generated by: Senior DevOps Engineer & Security Expert
# Framework: MERN Stack (MongoDB + Express + React + Node.js)
# ========================================

# ========================================
# SERVER CONFIGURATION (Backend)
# ========================================
# Server port
PORT=5000

# Environment mode
NODE_ENV=development

# Backend base URL (for frontend CORS)
BACKEND_URL=http://localhost:5000

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:3000

# ========================================
# DATABASE (MongoDB Atlas Recommended)
# ========================================
# MongoDB Connection String
# Format: mongodb+srv://user:pass@cluster.mongodb.net/marketplace
MONGO_URI=your_mongodb_atlas_connection_string_here

# Database name
DB_NAME=luxury_marketplace

# ========================================
# AUTHENTICATION (JWT - Security Critical)
# ========================================
# JWT Access Token Secret (Generate: openssl rand -base64 64)
JWT_SECRET=your_super_secure_jwt_secret_min_64_chars_here

# JWT Refresh Token Secret (Different from access token)
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars_here

# Token Expiration
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password Reset Token
JWT_RESET_EXPIRES_IN=1h

# ========================================
# PAYMENT GATEWAYS (💰 $10k+ Revenue Protection)
# ========================================
## STRIPE (Primary - Credit Cards)
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

## PAYPAL (Secondary Gateway)
# Developer: https://developer.paypal.com/developer/applications/
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

## COINBASE COMMERCE (Crypto - BTC/ETH/USDC)
# Commerce Dashboard: https://commerce.coinbase.com/
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_WEBHOOK_SHARED_SECRET=your_coinbase_webhook_secret_here

## PAYMOB (Middle East - Egypt KSA Support)
# Dashboard: https://dashboard.paymob.com/
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_IFRAME_ID=your_paymob_iframe_id_here

# ========================================
# CLOUD STORAGE (High-Quality Asset Images)
# ========================================
## CLOUDINARY (Primary - Recommended)
# Console: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

## AWS S3 (Enterprise Alternative)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=luxury-marketplace-assets
AWS_REGION=us-east-1

# ========================================
# FRONTEND CONFIGURATION (Vite Prefix Required)
# ========================================
# Backend API URL (Frontend → Backend)
VITE_API_URL=http://localhost:5000/api/v1

# Stripe Public Key (Frontend Only)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# PayPal Client ID (Frontend)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ========================================
# AI & INTELLIGENCE (Luxury Features)
# ========================================
## Google Gemini Pro (AI Recommendations)
# Makersuite: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

## OpenAI GPT-4o (Chat Assistant)
# Platform: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# EMAIL SERVICE (Transactional - SendGrid/Nodemailer)
# ========================================
# SendGrid (Recommended)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# SMTP (Alternative - Gmail/Outlook)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_verified_email@gmail.com
EMAIL_PASS=your_app_password_not_regular_password
EMAIL_FROM=noreply@luxury-marketplace.com

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here

# ========================================
# SECURITY & RATE LIMITING
# ========================================
# Brute Force Protection
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_DURATION_MINUTES=15

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (Frontend URLs)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com,https://luxury-marketplace.com

# ========================================
# GLOBAL CONFIGURATION
# ========================================
# App Branding
APP_NAME="Luxury Asset Marketplace"
APP_VERSION="1.0.0"

# Default Currency
DEFAULT_CURRENCY=USD

# Feature Flags
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_CRYPTO_PAYMENTS=true
ENABLE_CHAT_BOT=true

# ========================================
# ANALYTICS & MONITORING
# ========================================
# Google Analytics GA4
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# ========================================
# DEVELOPMENT & DEBUG
# ========================================
DEBUG_MODE=true
USE_MOCK_DATA=false

# ========================================
# PRODUCTION OVERRIDE (Cloud Deployment)
# ========================================
# Vercel/Railway/Heroku
DATABASE_URL=your_mongodb_connection_string
REDIS_URL=optional_redis_for_sessions

# ========================================
# SECURITY CHECKLIST 📋
# ========================================
# [ ] .env* added to .gitignore
# [ ] All payment webhooks configured
# [ ] Cloudinary transformation rules set
# [ ] SMTP verified (send test email)
# [ ] CORS origins validated
# [ ] Rate limits tested
# [ ] JWT secrets > 64 chars
# [ ] 2FA enabled on payment accounts

# ========================================
# PRODUCTION DEPLOYMENT COMMANDS
# ========================================
# Backend: npm run build && npm start
# Frontend: npm run build → static hosting
# Database: MongoDB Atlas (M10+ cluster)
# CDN: Cloudflare (Page Rules + Polish)
