# ========================================
# GLOBAL SERVER SETTINGS
# ========================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/marketplace
MONGO_URI=your_mongodb_connection_string_here

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
JWT_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
PASSWORD_RESET_EXPIRATION=1h

# ========================================
# FINANCIAL GATEWAYS (CRITICAL - $10k+ Revenue Protection)
# ========================================
## STRIPE
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

## PAYPAL
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox 

## COINBASE COMMERCE (Crypto)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_WEBHOOK_SHARED_SECRET=your_coinbase_webhook_secret_here

## PAYMOB (Egypt)
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_IFRAME_ID=your_paymob_iframe_id_here

# ========================================
# THIRD-PARTY INTEGRATIONS
# ========================================
## CLOUDINARY (Image Management)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

## AI ENGINES
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

## GOOGLE MAPS
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

## SHIPPING & LOGISTICS
SHIPENGINE_API_KEY=your_shipengine_api_key_here
ARAMEX_ACCOUNT_NUMBER=your_aramex_account
ARAMEX_USERNAME=your_username
ARAMEX_PASSWORD=your_password
ARAMEX_REGION=your_region

# ========================================
# SECURITY & RATE LIMITING
# ========================================
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_DURATION=15
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# EMAIL SERVICE
# ========================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
EMAIL_FROM=noreply@yourmarketplace.com

# ========================================
# DEPLOYMENT & CACHE
# ========================================
DATABASE_URL=your_atlas_connection_string
REDIS_URL=your_redis_url_if_used
