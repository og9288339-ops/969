# ========================================
# GLOBAL SERVER SETTINGS
# ========================================
# Server port (default: 5000)
PORT=5000

# Environment mode
NODE_ENV=development

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Atlas or self-hosted connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/marketplace?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
# JWT Access Token Secret (min 32 chars, generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_access_secret_here_min_32_chars

# JWT Refresh Token Secret (different from access)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars

# Token expiration (minutes/days)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Password reset token expiration (hours)
PASSWORD_RESET_EXPIRATION=1h

# ========================================
# FINANCIAL GATEWAYS (CRITICAL - $10k+ Revenue Protection)
# ========================================
## STRIPE (Primary Payment Gateway)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

## PAYPAL (Secondary Gateway)
# Get from: https://developer.paypal.com/developer/applications/
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox  # sandbox or live

## COINBASE COMMERCE (Crypto Payments)
# Get from: https://commerce.coinbase.com/
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_WEBHOOK_SHARED_SECRET=your_coinbase_webhook_secret_here

## PAYMOB (Middle East - Egypt)
# Get from: https://dashboard.paymob.com/
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_IFRAME_ID=your_paymob_iframe_id_here

# ========================================
# THIRD-PARTY INTEGRATIONS
# ========================================
## CLOUDINARY (Image Management)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

## GOOGLE GEMINI AI (AI Recommendations)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

## OPENAI GPT (Chat Assistant)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

## GOOGLE MAPS (Geocoding & Distance)
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

## SHIPPING APIs
## SHIPENGINE (Global Shipping)
# Get from: https://app.shipengine.com/
SHIPENGINE_API_KEY=your_shipengine_api_key_here

## ARAMEX (Middle East)
# Get from: Aramex Developer Portal
ARAMEX_ACCOUNT_NUMBER=your_aramex_account
ARAMEX_USERNAME=your_username
ARAMEX_PASSWORD=your_password
ARAMEX_REGION=your_region

# ========================================
# SECURITY & RATE LIMITING
# ========================================
# Brute force protection (failed logins per IP)
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_DURATION=15  # minutes

# API rate limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# EMAIL SERVICE (SendGrid/Mailgun)
# ========================================
# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Mailgun (alternative)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here

# Email sender
EMAIL_FROM=noreply@yourmarketplace.com

# ========================================
# BEST PRACTICES & SECURITY NOTES
# ========================================
# 1. NEVER commit real values to Git - use .env only
# 2. Add .env to .gitignore
# 3. Use different keys for development/staging/production
# 4. Rotate API keys every 90 days
# 5. Enable 2FA on all payment provider accounts
# 6. Monitor rate limit logs for abuse patterns
# 7. Use MongoDB Atlas with VPC peering for production
# 8. Set up Stripe/PayPal webhook endpoints in their dashboards
# 9. Test all webhooks in sandbox mode first
# 10. Backup .env.example in your documentation

# ========================================
# DEPLOYMENT OVERRIDE (Optional)
# ========================================
# For platforms like Vercel, Railway, Render
DATABASE_URL=your_atlas_connection_string
REDIS_URL=your_redis_url_if_used
