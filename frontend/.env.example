# ========================================
# .ENV.EXAMPLE - $10,000+ LUXURY MERN MARKETPLACE (FRONTEND)
# ========================================
# ⚠️  CRITICAL SECURITY WARNING ⚠️
# NEVER commit .env files with REAL values to Git!
# Add .env* to .gitignore
# Copy this file → .env.local → Fill with REAL values
# ========================================
# Generated by: Senior DevOps Engineer & Security Expert
# Framework: Vite + React 18/19 (All vars prefixed with VITE_)
# ========================================

# ========================================
# API & BACKEND ENDPOINTS (Critical)
# ========================================
# Backend API Base URL
VITE_API_URL=http://localhost:5000/api/v1

# WebSocket for real-time (orders, notifications)
VITE_SOCKET_URL=ws://localhost:5000

# GraphQL endpoint (if used)
VITE_GRAPHQL_URL=http://localhost:5000/graphql

# ========================================
# AUTHENTICATION & SECURITY
# ========================================
# JWT Configuration (rarely needed in frontend)
VITE_JWT_DOMAIN=yourdomain.com

# OAuth Providers
# Google OAuth (Social Login)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.googleusercontent.com

# GitHub OAuth
VITE_GITHUB_CLIENT_ID=your_github_client_id

# ========================================
# PAYMENT GATEWAYS (Financial Core - $10k+ Revenue)
# ========================================
# STRIPE (Primary - Credit Cards)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here
# Get from: https://dashboard.stripe.com/test/apikeys

# PAYPAL (Secondary)
VITE_PAYPAL_CLIENT_ID=your_sandbox_paypal_client_id_here
# Get from: https://developer.paypal.com/developer/applications/

# COINBASE COMMERCE (Crypto - BTC/ETH)
VITE_COINBASE_PUBLIC_KEY=your_coinbase_charge_public_key_here
# Get from: https://commerce.coinbase.com/

# PAYMOB (Middle East - Egypt)
VITE_PAYMOB_IFRAME_ID=your_paymob_iframe_id_here

# ========================================
# CLOUD STORAGE & CDN (Assets)
# ========================================
# CLOUDINARY (Primary - Product Images)
VITE_CLOUDINARY_CLOUD_NAME=demo
VITE_CLOUDINARY_PUBLIC_ID_PREFIX=luxury-marketplace
# Get from: https://cloudinary.com/console

# AWS S3 (Alternative - Enterprise)
VITE_S3_PUBLIC_BUCKET=luxury-marketplace-public.s3.amazonaws.com
VITE_S3_REGION=us-east-1

# ========================================
# AI & MACHINE LEARNING
# ========================================
# Google Gemini Pro (AI Recommendations)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Get from: https://makersuite.google.com/app/apikey

# OpenAI GPT-4o (Chat Assistant - Fallback)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# ANALYTICS & MONITORING
# ========================================
# Google Analytics / GA4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
VITE_GTM_ID=GTM-XXXXXXX

# Amplitude (Advanced Analytics)
VITE_AMPLITUDE_API_KEY=your_amplitude_key_here

# ========================================
# FEATURE FLAGS (Enterprise Control)
# ========================================
# Enable/Disable Features
VITE_ENABLE_AI_RECOMMENDATIONS=true
VITE_ENABLE_CHAT_BOT=true
VITE_ENABLE_CRYPTO_PAYMENTS=true

# Maintenance Mode
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE=Platform under scheduled maintenance

# A/B Testing
VITE_EXPERIMENT_VARIANT=A

# ========================================
# GLOBAL CONFIGURATION
# ========================================
# App Branding
VITE_APP_NAME="Luxury Asset Marketplace"
VITE_APP_TAGLINE="Premier Platform for Elite Acquisitions"
VITE_APP_VERSION="1.0.0"

# Environment
VITE_APP_ENV=development

# Currency (Multi-Currency Support)
VITE_DEFAULT_CURRENCY=USD
VITE_SUPPORTED_CURRENCIES=USD,EGP,EUR,BTC

# ========================================
# SOCIAL & MARKETING
# ========================================
# Social Media Sharing
VITE_SOCIAL_TWITTER=yourmarketplace
VITE_SOCIAL_FACEBOOK=https://facebook.com/yourmarketplace
VITE_SOCIAL_INSTAGRAM=yourmarketplace

# Open Graph Defaults
VITE_OG_TITLE="Luxury Asset Marketplace"
VITE_OG_DESCRIPTION="Discover exclusive luxury assets with AI-powered recommendations"
VITE_OG_IMAGE=/og-image.jpg

# ========================================
# DEVELOPMENT & DEBUGGING
# ========================================
# Enable console warnings in development
VITE_DEBUG_MODE=true

# Mock API responses for development
VITE_USE_MOCK_API=false

# ========================================
# SECURITY & COMPLIANCE
# ========================================
# CSP Nonce (Content Security Policy)
VITE_CSP_NONCE=nonce-random-string

# Report URI for security monitoring
VITE_SECURITY_REPORT_URI=https://your-report-uri.com

# ========================================
# DEPLOYMENT OVERRIDE (Cloud Platforms)
# ========================================
# Vercel/Netlify/Railway
VITE_DEPLOYMENT_ENV=production
VITE_BUILD_NUMBER=%BUILD_NUMBER%

# ========================================
# SETUP INSTRUCTIONS 📋
# ========================================
# 1. Copy this file → .env.local
# 2. Fill ALL placeholders with REAL values
# 3. Add .env* to .gitignore (CRITICAL!)
# 4. npm install → Zero errors
# 5. npm run dev → Instant startup
# 6. Configure payment gateways in their dashboards
# 7. Test Stripe/PayPal webhooks in sandbox mode first

# ========================================
# SECURITY BEST PRACTICES 🔒
# ========================================
# ✅ Use 2FA on ALL payment provider accounts
# ✅ Rotate API keys every 90 days
# ✅ Monitor rate limit logs for abuse
# ✅ Never expose private keys in frontend
# ✅ Use HTTPS in production (VITE_HTTPS=true)
# ✅ Enable CSP headers in production
# ✅ Audit dependencies weekly (npm audit)

# ========================================
# PRODUCTION CHECKLIST ✅
# ========================================
# [ ] All payment gateways configured
# [ ] Cloudinary bucket permissions set
# [ ] AI API keys active
# [ ] Analytics tracking verified
# [ ] Social OAuth callbacks registered
# [ ] Webhook endpoints tested
# [ ] Environment variables validated
