{
  "name": "luxury-mern-monorepo",
  "version": "1.0.0",
  "description": "$10,000+ Enterprise Luxury MERN Marketplace - Monorepo",
  "author": "Senior DevOps & Full-Stack Architect",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "build": "npm run build-backend && npm run build-frontend",
    "build-frontend": "cd frontend && npm run build",
    "build-backend": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "preview": "concurrently \"npm run backend\" \"npm run preview-frontend\"",
    "preview-frontend": "cd frontend && npm run preview",
    "lint": "npm run lint-backend && npm run lint-frontend",
    "lint-backend": "cd backend && npm run lint",
    "lint-frontend": "cd frontend && npm run lint",
    "test": "npm run test-backend && npm run test-frontend",
    "test-backend": "cd backend && npm test",
    "test-frontend": "cd frontend && npm test",
    "clean": "npm run clean-backend && npm run clean-frontend",
    "clean-backend": "cd backend && rm -rf node_modules dist",
    "clean-frontend": "cd frontend && rm -rf node_modules dist .vite"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "frontend/**/*.{js,ts,jsx,tsx}": "cd frontend && npm run lint:fix",
    "backend/**/*.{js,ts}": "cd backend && npm run lint:fix",
    "*.{js,ts,jsx,tsx,md,json}": "prettier --write"
  },
  "keywords": [
    "mern",
    "ecommerce",
    "luxury",
    "marketplace",
    "monorepo",
    "enterprise",
    "vite",
    "react",
    "express",
    "mongodb"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/luxury-mern-marketplace/monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/luxury-mern-marketplace/monorepo/issues"
  },
  "homepage": "https://luxury-mern-marketplace.com",
  "enginesStrict": true,
  "packageManager": "npm@9.8.1"
}
