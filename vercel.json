{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      }
    },
    {
      "src": "/_next/static/(.*)",
      "headers": {
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      }
    },
    {
      "src": "/static/(.*)",
      "headers": {
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      }
    },
    {
      "src": "/favicon.ico",
      "headers": {
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      }
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options
